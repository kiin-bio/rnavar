/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args    = Additional arguments appended to command in module.
        ext.args2   = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3   = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix  = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

// PREPARE GENOME
process {
    withName: CAT_FASTQ {
        publishDir = [
            path: { "${params.outdir}/fastq" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_merged_fastq
        ]
    }

    withName: STAR_INDEXVERSION {
        tag        = { params.genome ?: 'custom_genome' }
        publishDir = [
            enabled: false
        ]
    }

    withName: UNTAR {
        tag        = { meta.id }
        publishDir = [
            enabled: false
        ]
    }

    withName: REMOVEUNKNOWNREGIONS {
        ext.prefix = { "${meta.id}.exon" }
        publishDir = [
            path: { "${params.outdir}/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }

    withName: STAR_GENOMEGENERATE {
        ext.args   = { params.read_length ? "--sjdbOverhang ${params.read_length - 1}" : '' }
        publishDir = [
            path: { "${params.outdir}/genome/index" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }

    withName: GFFREAD {
        ext.args   = '--keep-exon-attrs -F -T'
        publishDir = [
            path: { "${params.outdir}/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ?null : filename },
            enabled: params.save_reference
        ]
    }

    withName: GTF2BED {
        tag        = { meta.id }
        publishDir = [
            path: { "${params.outdir}/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }


    withName: SAMTOOLS_FAIDX {
        tag        = { meta.id }
        publishDir = [
            path: { "${params.outdir}/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }

    withName: GATK4_CREATESEQUENCEDICTIONARY {
        publishDir = [
            path: { "${params.outdir}/genome" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.save_reference
        ]
    }
}

// READ QC AND QC REPORT
process {
    withName: MULTIQC {
        ext.args   = { params.multiqc_title ? "--title \"${params.multiqc_title}\"" : '' }
    }

    withName: MOSDEPTH {
        publishDir = [
            path: { "${params.outdir}/reports/stats/${meta.id}/mosdepth/" },
            mode: params.publish_dir_mode,
            pattern: "*.{mosdepth.global.dist.txt,mosdepth.summary.txt,per-base.bed.gz,per-base.bed.gz.csi}"
        ]
    }

    withName: FASTQC {
        ext.args   = { '--quiet' }
        publishDir = [
            [
                path: { "${params.outdir}/reports/stats/${meta.id}/fastqc/" },
                mode: params.publish_dir_mode,
                pattern: "*{html,zip}"
            ]
        ]
    }
}

// ALIGNMENT
process {
    withName: UMITOOLS_EXTRACT {
        ext.args   = {
            def args = []
            args += [
                params.umitools_bc_pattern ? "--bc-pattern='${params.umitools_bc_pattern}'" : '',
                params.umitools_bc_pattern2 && !meta.single_end ? "--bc-pattern2='${params.umitools_bc_pattern2}'" : '',
                params.umitools_extract_method ? "--extract-method=${params.umitools_extract_method}" : '',
                params.umitools_umi_separator ? "--umi-separator='${params.umitools_umi_separator}'" : '',
            ]
            args.join(' ')
        }
        publishDir = [
            [
                path: { "${params.outdir}/preprocessing/umitools/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.{fastq.gz}'
            ],
            [
                path: { "${params.outdir}/reports/stats/${meta.id}/umitools/" },
                mode: params.publish_dir_mode,
                pattern: '*.{log}'
            ]
        ]
    }

    withName: STAR_ALIGN {
        ext.args   = {
            def args = []

            // Read group tags - assembled once from samplesheet meta and pipeline params
            // Per-sample meta values take priority over global params
            def rgParts = ["'ID:${meta.id}'", "'SM:${meta.id}'"]

            def seqCenter = meta.seq_center ?: params.seq_center
            if (seqCenter) { rgParts << "'CN:${seqCenter}'" }

            def seqPlatform = meta.seq_platform ?: params.seq_platform
            if (seqPlatform) { rgParts << "'PL:${seqPlatform}'" }

            args += [
                "--outSAMattrRGline ${rgParts.join(' ')}",
                '--outSAMtype BAM SortedByCoordinate',
                '--readFilesCommand zcat',
                params.read_length ? "--sjdbOverhang ${params.read_length - 1}" : '',
                params.save_unaligned ? '--outReadsUnmapped Fastx' : '',
                params.star_bins_bamsort > 0 ? "--outBAMsortingBinsN ${params.star_bins_bamsort}" : '',
                params.star_max_collapsed_junc > 0 ? "--limitOutSJcollapsed ${params.star_max_collapsed_junc}" : '',
                params.star_max_intron_size ? "--alignIntronMax ${params.star_max_intron_size}" : '',
                params.star_max_memory_bamsort > 0 ? "--limitBAMsortRAM ${params.star_max_memory_bamsort}" : '',
                params.star_twopass ? '--twopassMode Basic' : '',
            ]
            args.join(' ')
        }
        publishDir = [
            [
                path: { "${params.outdir}/reports/stats/${meta.id}/STAR_log" },
                mode: params.publish_dir_mode,
                pattern: '*.{out,tab}'
            ],
            [
                path: { "${params.outdir}/preprocessing/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: '*.bam',
                enabled: false
            ],
            [
                path: { "${params.outdir}/preprocessing/${meta.id}/unmapped" },
                mode: params.publish_dir_mode,
                pattern: '*.fastq.gz',
                enabled: params.save_unaligned
            ]
        ]
    }
}

// POST ALIGNMENT AND PREPROCESSING BAM
process {
    withName: '.*:FASTQ_ALIGN_STAR:BAM_SORT_STATS_SAMTOOLS_GENOME:SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}.aligned" }
        publishDir = [
            path: { "${params.outdir}/preprocessing/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.bam",
            enabled: params.save_align_intermeds
        ]
    }

    withName: '.*:FASTQ_ALIGN_STAR:BAM_SORT_STATS_SAMTOOLS_GENOME:SAMTOOLS_INDEX' {
        ext.args   = { params.bam_csi_index ? '-c' : '' }
        ext.prefix = { "${meta.id}.aligned" }
        publishDir = [
            path: { "${params.outdir}/preprocessing/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{bai,csi}",
            enabled: params.save_align_intermeds
        ]
    }

    withName: GATK4_BEDTOINTERVALLIST {
        ext.args   = '--DROP_MISSING_CONTIGS TRUE'
        publishDir = [ enabled: false ]
    }

    withName: GATK4_INTERVALLISTTOOLS {
        ext.args   = {
            def args = []
            args += [
                '--SORT true',
                '--SUBDIVISION_MODE BALANCING_WITHOUT_INTERVAL_SUBDIVISION_WITH_OVERFLOW',
                '--UNIQUE true',
                params.gatk_interval_scatter_count ? "--SCATTER_COUNT ${params.gatk_interval_scatter_count}" : ''
            ]
            args.join(' ')
        }
        publishDir  = [ enabled: false ]
    }

    withName: PICARD_MARKDUPLICATES {
        ext.args   = {
            def args = []
            args += [
                '--ASSUME_SORTED true',
                '--VALIDATION_STRINGENCY LENIENT',
                params.remove_duplicates ? '--REMOVE_DUPLICATES true' : ''
            ]
            args.join(' ')
        }
        ext.prefix = { "${meta.id}.md" }
        publishDir = [
            [
                path: { "${params.outdir}/preprocessing/${meta.id}" },
                mode: params.publish_dir_mode,
                enabled: true,
                pattern: "*.{bam,bai,csi}"
            ],
            [
                path: { "${params.outdir}/reports/stats/${meta.id}/markduplicates/" },
                mode: params.publish_dir_mode,
                enabled: true,
                pattern: "*.metrics.txt"
            ]
        ]
    }

    withName: '.*:BAM_MARKDUPLICATES_PICARD:SAMTOOLS_INDEX' {
        ext.args   = { params.bam_csi_index ? '-c' : '' }
        ext.prefix = { "${meta.id}.md" }
        publishDir = [
            path: { "${params.outdir}/preprocessing/${meta.id}" },
            mode: params.publish_dir_mode,
            enabled: true,
            pattern: "*.{bai,csi}"
        ]
    }

    withName: GATK4_SPLITNCIGARREADS {
        ext.args   =  '--create-output-bam-index false'
        ext.prefix = { "${meta.id}.splitncigarreads" }
    }

    withName: '.*:SPLITNCIGAR:SAMTOOLS_INDEX' {
        ext.args   =  { params.bam_csi_index ? '-c' : '' }
    }

    withName: '.*:SPLITNCIGAR:.*' {
        publishDir = [ enabled: false ]
    }

    withName: '.*:BAM_SORT_STATS_SAMTOOLS_GENOME:BAM_STATS_SAMTOOLS:(SAMTOOLS_FLAGSTAT|SAMTOOLS_IDXSTATS|SAMTOOLS_STATS)' {
        ext.prefix  = { "${meta.id}.aligned" }
    }

    withName: '.*:BAM_MARKDUPLICATES_PICARD:BAM_STATS_SAMTOOLS:(SAMTOOLS_FLAGSTAT|SAMTOOLS_IDXSTATS|SAMTOOLS_STATS)' {
        ext.prefix  = { "${meta.id}.md" }
    }

    withName: '.*:RECALIBRATE:BAM_STATS_SAMTOOLS:(SAMTOOLS_FLAGSTAT|SAMTOOLS_IDXSTATS|SAMTOOLS_STATS)' {
        ext.prefix  = { "${meta.id}.recal" }
    }

    withName: 'SAMTOOLS_FLAGSTAT|SAMTOOLS_IDXSTATS|SAMTOOLS_STATS' {
        publishDir  = [
            path: { "${params.outdir}/reports/stats/${meta.id}/samtools/" },
            mode: params.publish_dir_mode,
            pattern: "*.{flagstat,idxstats,stats}"
        ]
    }
}

// BASE RECALIBRATION PROCESS
process {
    withName: GATK4_BASERECALIBRATOR {
        ext.args   =  '--use-original-qualities'
        publishDir = [ enabled: false ]
    }

    withName: GATK4_APPLYBQSR {
        ext.args   = {
            def args = []
            args += [
                '--add-output-sam-program-record',
                '--use-original-qualities',
            ]
            args.join(' ')
        }
        ext.prefix = { "${meta.id}.recal" }
        ext.suffix = 'bam'
        publishDir = [
            path: { "${params.outdir}/preprocessing/${meta.id}" },
            mode: params.publish_dir_mode,
            enabled: true,
            pattern: "*.{bam}"
        ]
    }

    withName: '.*:RECALIBRATE:SAMTOOLS_INDEX' {
        ext.args   = { params.bam_csi_index ? '-c' : '' }
        ext.prefix = { "${meta.id}.recal" }
        publishDir = [
            path: { "${params.outdir}/preprocessing/${meta.id}" },
            mode: params.publish_dir_mode,
            enabled: true,
            pattern: "*.{bai,csi}"
        ]
    }
}

// HLATyping
process {
    withName: SEQ2HLA {
        publishDir = [
            path: { "${params.outdir}/seq2hla/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

// VARIANT CALLING AND FILTERING
process {
    withName: GATK4_HAPLOTYPECALLER {
        ext.args   = {
            def args = []
            args += [
                '--create-output-variant-index true',
                '--dont-use-soft-clipped-bases',
                params.gatk_hc_call_conf ? "--standard-min-confidence-threshold-for-calling ${params.gatk_hc_call_conf}" : '',
                params.tools && params.tools.contains('combinegvcfs') ? "-ERC GVCF" : ''
            ]
            args.join(' ')
        }
        publishDir = [ enabled: false ]
    }

    withName: GATK4_MERGEVCFS {
        ext.prefix = { "${meta.id}.haplotypecaller" }
        publishDir = [
            path: { "${params.outdir}/variant_calling/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{vcf.gz}"
        ]
    }

    withName: GATK4_COMBINEGVCFS {
        ext.prefix = { "${meta.id}.haplotypecaller" }
        publishDir = [
            path: { "${params.outdir}/variant_calling/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{vcf.gz}"
        ]
    }

    withName: TABIX_TABIX {
        ext.args   = { params.bam_csi_index ? '--csi' : '' }
        ext.prefix = { "${meta.id}.haplotypecaller" }
        publishDir = [
            path: { "${params.outdir}/variant_calling/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{tbi,csi}"
        ]
    }

    withName: GATK4_VARIANTFILTRATION {
        ext.prefix = { "${meta.id}.haplotypecaller.filtered" }
        ext.args   = {
            def args = []
            args += [
                params.gatk_vf_cluster_size ? "--cluster-size ${params.gatk_vf_cluster_size}" : '',
                params.gatk_vf_fs_filter ? "--filter-name \"FS\" --filter-expression \"FS > ${params.gatk_vf_fs_filter}\" " : '',
                params.gatk_vf_qd_filter ? "--filter-name \"QD\" --filter-expression \"QD < ${params.gatk_vf_qd_filter}\" " : '',
                params.gatk_vf_window_size ? "--cluster-window-size ${params.gatk_vf_window_size}" : '',
            ]
            args.join(' ')
        }
        publishDir = [
            path: { "${params.outdir}/variant_calling/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{vcf.gz,vcf.gz.tbi}"
        ]
    }
}
