/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Kiin Bio production profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Process resources are based on production RNA-VAR execution traces. Memory scales on
    retry while CPU requests remain stable to avoid unnecessary node expansion.
----------------------------------------------------------------------------------------
*/

params.gatk_interval_scatter_count = 40

process {
    withName: 'NFCORE_RNAVAR:RNAVAR:FASTQ_ALIGN_STAR:STAR_ALIGN' {
        cpus   = 12
        memory = { 52.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:BAM_MARKDUPLICATES_PICARD:PICARD_MARKDUPLICATES' {
        cpus       = 2
        memory     = { 36.GB * task.attempt }
        publishDir = [enabled: false]
    }

    withName: 'NFCORE_RNAVAR:PREPARE_GENOME:GTF2BED' {
        cpus   = 1
        memory = { 4.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:GATK4_BEDTOINTERVALLIST' {
        cpus   = 2
        memory = { 2.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:GATK4_INTERVALLISTTOOLS' {
        cpus   = 2
        memory = { 4.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:SPLITNCIGAR:GATK4_SPLITNCIGARREADS' {
        cpus   = 1
        memory = { 6.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:GATK4_HAPLOTYPECALLER' {
        cpus   = 2
        memory = { 4.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:VCF_ANNOTATE_ALL:VCF_ANNOTATE_ENSEMBLVEP:ENSEMBLVEP_VEP' {
        cpus   = 3
        memory = { 4.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:FASTQ_ALIGN_STAR:BAM_SORT_STATS_SAMTOOLS_GENOME:SAMTOOLS_SORT' {
        cpus   = 4
        memory = { 8.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:FASTQC' {
        cpus   = 2
        memory = { 6.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:SPLITNCIGAR:SAMTOOLS_MERGE' {
        cpus   = 2
        memory = { 4.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:GATK4_MERGEVCFS' {
        cpus   = 2
        memory = { 4.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:GATK4_VARIANTFILTRATION' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:.*:SAMTOOLS_INDEX' {
        cpus   = 2
        memory = { 2.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:.*:SAMTOOLS_STATS' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:.*:SAMTOOLS_FLAGSTAT' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
    }

    withName: 'NFCORE_RNAVAR:RNAVAR:.*:SAMTOOLS_IDXSTATS' {
        cpus   = 1
        memory = { 2.GB * task.attempt }
    }

    withName: '^MULTIQC$' {
        cpus   = 1
        memory = { 3.GB * task.attempt }
    }
}
