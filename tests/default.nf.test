nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"
    tag "pipeline_rnavar"

    def test_scenario = [
        [
            name: "-profile test",
            params: [],
        ],
        [
            name: "-profile test --dbsnp false --dbsnp_tbi false --known_indels_tbi false",
            params: [
                dbsnp: false,
                dbsnp_tbi: false,
                known_indels_tbi: false,
            ],
        ],
        [
            name: "-profile test --dbsnp_tbi false --known_indels false --known_indels_tbi false",
            params: [
                dbsnp_tbi: false,
                known_indels: false,
                known_indels_tbi: false,
            ],
        ],
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
