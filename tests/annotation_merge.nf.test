def projectDir = new File('.').absolutePath

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"
    tag "pipeline_rnavar"

    def test_scenario = [
        [
            name: "-profile test --tools merge",
            params: [
                input: "${projectDir}/tests/csv/1.0/vcf.csv",
                tools: "merge"
            ]
        ],
            [
            name: "-profile test --tools merge,snpeff,vep",
            params: [
                input: "${projectDir}/tests/csv/1.0/vcf.csv",
                tools: "merge,snpeff,vep"
            ]
        ]
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.getTest(scenario))
    }
}
