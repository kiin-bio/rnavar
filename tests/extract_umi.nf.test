def projectDir = new File('.').absolutePath

nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"
    tag "pipeline_rnavar"

    def test_scenario = [
        [
            name: "-profile test --extract_umi",
            params: [
                extract_umi: true,
                input: "${projectDir}/tests/csv/1.0/fastq_single_end.csv",
                umitools_bc_pattern: "NNNXC"
            ]
        ]
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.get_test(scenario))
    }
}
